    "attributes": {
        "action": "Add \u2018Security Officer\u2019 to the recognised profession list on GOV passport website",
        "additional_details": "All Security Officers in the security industry are licensed and have a clean criminal record and are trusted to keep the public safe. They should be a recognised profession.",
        "background": "The position of \u2018Security Officer\u2019 should be added to the recognised profession list in order to be able to countersign for passport applications.",
