    "attributes": {
        "action": "Mandate neurodiversity training for all school staff",
        "additional_details": "",
        "background": "Introduce mandatory training for all staff in schools, including teachers, to be more aware of neurodiverse children. We believe by doing so we can ensure neurodiverse children get their needs met, so they feel more accepted in school.",
