    "attributes": {
        "action": "Detain anyone arriving in the UK illegally",
        "additional_details": "",
        "background": "We believe that anyone arriving into the UK illegally should be detained in the hotel/migrant accommodation until they are deported as they have arrived without the proper documentation. Such accommodation could include temporary camps.",
